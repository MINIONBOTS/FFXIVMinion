# Simple, Sourcetree-friendly repo ignore rules.
# Ignore runtime folders by default, keep source roots visible.
/*
!/.gitignore

!/Dev/
!/Dev/**/
!/Dev/**/*.lua
!/Dev/**/*.def

!/ffxivminion/
!/ffxivminion/**/
!/ffxivminion/**/*.lua
!/ffxivminion/**/*.info
!/ffxivminion/**/*.mml
!/ffxivminion/**/*.def
!/ffxivminion/**/*.md

!/translations/
!/translations/**/
!/translations/**/*.lua
!/translations/**/*.def
!/translations/**/*.db
!/translations/**/*.png

# Runtime logs
log.txt
