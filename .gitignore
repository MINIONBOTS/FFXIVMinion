# Simple, Sourcetree-friendly repo ignore rules.
# Ignore runtime folders by default, keep source roots visible.
/*
!/.gitignore

!/Dev/
!/Dev/**/
!/Dev/**/*.lua
!/Dev/**/*.def

!/ffxivminion/
!/ffxivminion/**/
!/ffxivminion/**/*.lua
!/ffxivminion/**/*.info
!/ffxivminion/**/*.mml
!/ffxivminion/**/*.def
!/ffxivminion/**/*.md

!/translations/

# Runtime/profile data not tracked from active folder
/ffxivminion/SkillManagerProfiles/
/ffxivminion/class_routines/**/*.info
!/translations/**/
!/translations/**/*.lua
!/translations/**/*.def
!/translations/**/*.db
!/translations/**/*.png

# Runtime logs
log.txt

# Runtime/local docs
Docs/
**/Docs/
ffxivminion/.codex/relevent-files.MD
